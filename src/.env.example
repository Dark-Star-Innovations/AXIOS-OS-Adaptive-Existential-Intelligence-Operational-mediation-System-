# =========================
# AXIOS OS ENVIRONMENT
# =========================

# API KEYS
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HUGGINGFACE_API_KEY=

# MODEL CONFIGURATION
MODEL_NAME=deepseek-ai/deepseek-coder
MODEL_PATH=./models

# SERVER CONFIG
HOST=0.0.0.0
PORT=8000
DEBUG=True

# DATABASE
DATABASE_URL=sqlite:///./axios_os.db

# MEMORY SYSTEMS
MEMORY_PATH=./data/memory
EMBEDDINGS_PATH=./data/embeddings

# LOGGING
LOG_LEVEL=INFO
LOG_PATH=./logs

# TELEMETRY
ENABLE_TELEMETRY=True

# CONSTRAINT SYSTEM
ENABLE_CONSTRAINTS=True
ENABLE_DECEPTION_MONITOR=True

# IDENTITY ENGINE
ENABLE_IDENTITY_TRACKING=True

# META GOVERNANCE
ENABLE_META_REFLECTION=True

# SIMULATION MODE
ENABLE_SIMULATIONS=False
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MODEL_PATH=
DATABASE_URL=
